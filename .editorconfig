root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.py]
indent_style = space
max_line_length = 88
indent_size = 4

[*.pyi]
indent_style = space
max_line_length = 88
indent_size = 4

[*.{yml,yaml,toml}]
indent_style = space
indent_size = 2

[*.toml]
max_line_length = 80

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
